<script>
// ══════════════════════════════════════════════
// DATA
// ══════════════════════════════════════════════
const SPS = {
  pg:       [['2','Écharpes'],['10','Masques chirurgicaux'],['10','Paires de gants XL'],['1','Collecteur DASRI'],['1','Rlx de sacs poubelle']],
  rouge:    [['10','Compresses'],['3','Pansements américains'],['3','Dosettes NaCl 10 ml'],['1','Pansement israélien'],['1','Garrot tourniquet'],['3','Bandes 10 cm'],['1','Sparadrap'],['1','Ciseau GESCO'],['2','Couvertures de survie']],
  violette: [['1','Carnet et stylo'],['1','Stéthoscope'],['1','Tensiomètre manuel'],['1','Thermomètre auriculaire'],['1','Lampe à pupilles']],
  bleue:    [['1','BAVU enfant'],['1','MHC pédiatrique'],['1','Canule Guédel T00'],['1','Canule Guédel T1']],
  devant:   [['1','Détecteur de monoxyde (CO)']],
  pcarr:    [['1','Bouteille Oxy 5 L'],['1','Collier cervical adulte'],['1','Collier cervical enfant']],
  verte:    [['1','Lecteur glycémie'],['5','Lancettes'],['1','Dosette NACL'],['5','Compresses'],['20','Sucres emballés']],
  pd:       [['1','BAVU adulte'],['2','MHC adulte'],['1','Canule guédel T2'],['1','Canule guédel T3'],['1','Canule guédel T4'],['1','Lunette oxy'],['2','Lunettes de protection'],['2','Vomix']]
};
const DSA_LIST = [
  ['1','Appareil DSA (Défibrillateur Semi-Automatique)'],
  ['1','Paire d\'électrodes adultes (en place)'],
  ['1','Paire d\'électrodes pédiatriques (ou sélecteur)'],
  ['1','Kit de préparation (rasoir, ciseaux, compresses, gants)']
];

// ══════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════
let spsC={}, spsI={};
let dsaC={}, dsaI={}, dsaBat='';
let vsavC={}, vsavI={}, vsavItems=[];
let history=[];

function loadState() {
  spsC=JSON.parse(localStorage.getItem('ch4_sps_c')||'{}');
  spsI=JSON.parse(localStorage.getItem('ch4_sps_i')||'{}');
  dsaC=JSON.parse(localStorage.getItem('ch4_dsa_c')||'{}');
  dsaI=JSON.parse(localStorage.getItem('ch4_dsa_i')||'{}');
  dsaBat=localStorage.getItem('ch4_dsa_bat')||'';
  vsavC=JSON.parse(localStorage.getItem('ch4_vsav_c')||'{}');
  vsavI=JSON.parse(localStorage.getItem('ch4_vsav_i')||'{}');
  vsavItems=JSON.parse(localStorage.getItem('ch4_vsav_items')||'[]');
  history=JSON.parse(localStorage.getItem('ch4_history')||'[]');
}
function saveState() {
  localStorage.setItem('ch4_sps_c',JSON.stringify(spsC));
  localStorage.setItem('ch4_sps_i',JSON.stringify(spsI));
  localStorage.setItem('ch4_dsa_c',JSON.stringify(dsaC));
  localStorage.setItem('ch4_dsa_i',JSON.stringify(dsaI));
  localStorage.setItem('ch4_dsa_bat',dsaBat);
  localStorage.setItem('ch4_vsav_c',JSON.stringify(vsavC));
  localStorage.setItem('ch4_vsav_i',JSON.stringify(vsavI));
  localStorage.setItem('ch4_vsav_items',JSON.stringify(vsavItems));
  localStorage.setItem('ch4_history',JSON.stringify(history));
}

// ══════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════
function init() {
  loadState();
  const today = new Date().toISOString().slice(0,10);
  document.getElementById('hdate').textContent = new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'short'});
  ['sps','dsa','vsav'].forEach(p=>{
    const info = p==='sps'?spsI:p==='dsa'?dsaI:vsavI;
    document.getElementById(p+'-date').value = info.date||today;
    if(info.realise) document.getElementById(p+'-realise').value=info.realise;
    if(info.garde) document.getElementById(p+'-garde').value=info.garde;
    if(info.remarques) document.getElementById(p+'-remarques').value=info.remarques;
  });
  renderSps(); renderDsa(); renderVsav();
  loadDashboard();
}

// ══════════════════════════════════════════════
// VIEWS
// ══════════════════════════════════════════════
let currentView='dash';
function showView(v) {
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active'));
  document.getElementById('view-'+v).classList.add('active');
  document.getElementById('nav-'+v).classList.add('active');
  currentView=v;
  if(v==='hist') renderHistory();
  if(v==='dash') loadDashboard();
}

// ══════════════════════════════════════════════
// ROW BUILDER
// ══════════════════════════════════════════════
function buildRows(cid, items, checks, prefix, fn) {
  const c=document.getElementById(cid); c.innerHTML='';
  items.forEach(([qty,name],i)=>{
    const k=prefix+'_'+i, st=checks[k]||'';
    const row=document.createElement('div'); row.className='check-row';
    row.innerHTML=`
      <span class="qty-tag">${qty}</span>
      <span class="item-name">${name}</span>
      <div class="btn-pa">
        <button class="pa-btn ${st==='P'?'p':''}" onclick="${fn}('${k}','P')">P</button>
        <button class="pa-btn ${st==='A'?'a':''}" onclick="${fn}('${k}','A')">A</button>
      </div>`;
    c.appendChild(row);
  });
}

function updateOv(pfx, checks, total) {
  const p=Object.values(checks).filter(v=>v==='P').length;
  const a=Object.values(checks).filter(v=>v==='A').length;
  const n=total-p-a, pct=total?Math.round(p/total*100):0;
  document.getElementById(pfx+'-p').textContent=p;
  document.getElementById(pfx+'-a').textContent=a;
  document.getElementById(pfx+'-n').textContent=n;
  document.getElementById(pfx+'-pct').textContent=pct+'%';
  const bar=document.getElementById(pfx+'-bar');
  bar.style.width=pct+'%';
  bar.style.background=a>0?'var(--red)':pct===100?'var(--green)':'var(--orange)';
}

// ══════════════════════════════════════════════
// SPS
// ══════════════════════════════════════════════
window.spsChk=(k,v)=>{ spsC[k]=spsC[k]===v?'':v; saveState(); renderSps(); };
function renderSps() {
  Object.keys(SPS).forEach(s=>buildRows('rows-'+s, SPS[s], spsC, s, 'spsChk'));
  const total=Object.values(SPS).reduce((s,a)=>s+a.length,0);
  updateOv('sps',spsC,total);
  const pgP=Object.keys(spsC).filter(k=>k.startsWith('pg_')&&spsC[k]==='P').length;
  const el=document.getElementById('prog-pg');
  if(el) el.textContent=`${pgP}/${SPS.pg.length}`;
}
function saveSpsInfo() {
  spsI={realise:document.getElementById('sps-realise').value,date:document.getElementById('sps-date').value,garde:document.getElementById('sps-garde').value,remarques:document.getElementById('sps-remarques').value};
  saveState();
}
function saveSpsControl() {
  const total=Object.values(SPS).reduce((s,a)=>s+a.length,0);
  const p=Object.values(spsC).filter(v=>v==='P').length;
  const a=Object.values(spsC).filter(v=>v==='A').length;
  const absL=[];
  Object.entries(SPS).forEach(([s,items])=>items.forEach(([,n],i)=>{ if(spsC[s+'_'+i]==='A') absL.push(n); }));
  history.unshift({type:'sps',realise:spsI.realise||'—',garde:spsI.garde||'—',date:spsI.date||today(),total,p,a,absL,remarques:spsI.remarques||''});
  saveState();
  autoExportExcel();
  toast('✓ Enregistré — Excel mis à jour 📊'); loadDashboard();
}
function resetSps(){ if(!confirm('Réinitialiser ?')) return; spsC={}; saveState(); renderSps(); }

// ══════════════════════════════════════════════
// DSA
// ══════════════════════════════════════════════
window.dsaChk=(k,v)=>{ dsaC[k]=dsaC[k]===v?'':v; saveState(); renderDsa(); };
function renderDsa() {
  buildRows('rows-dsa',DSA_LIST,dsaC,'dsa','dsaChk');
  updateOv('dsa',dsaC,DSA_LIST.length);
  document.getElementById('bat-ok').className='bat-btn'+(dsaBat==='ok'?' ok':'');
  document.getElementById('bat-low').className='bat-btn'+(dsaBat==='low'?' low':'');
}
function setBat(v){ dsaBat=dsaBat===v?'':v; saveState(); renderDsa(); }
function saveDsaInfo(){ dsaI={realise:document.getElementById('dsa-realise').value,date:document.getElementById('dsa-date').value,garde:document.getElementById('dsa-garde').value,remarques:document.getElementById('dsa-remarques').value}; saveState(); }
function saveDsaControl() {
  const p=Object.values(dsaC).filter(v=>v==='P').length;
  const a=Object.values(dsaC).filter(v=>v==='A').length;
  const absL=DSA_LIST.map(([,n],i)=>dsaC['dsa_'+i]==='A'?n:null).filter(Boolean);
  if(dsaBat==='low') absL.push('Batterie faible');
  history.unshift({type:'dsa',realise:dsaI.realise||'—',garde:dsaI.garde||'—',date:dsaI.date||today(),total:DSA_LIST.length,p,a,absL,battery:dsaBat,remarques:dsaI.remarques||''});
  saveState();
  autoExportExcel();
  toast('✓ Enregistré — Excel mis à jour 📊'); loadDashboard();
}
function resetDsa(){ if(!confirm('Réinitialiser ?')) return; dsaC={}; dsaBat=''; saveState(); renderDsa(); }

// ══════════════════════════════════════════════
// VSAV
// ══════════════════════════════════════════════
window.vsavChk=(i,v)=>{ const k='vsav_'+i; vsavC[k]=vsavC[k]===v?'':v; saveState(); renderVsav(); };
window.delVsav=(i)=>{ vsavItems.splice(i,1); const nc={}; vsavItems.forEach((_,j)=>{if(vsavC['vsav_'+j])nc['vsav_'+j]=vsavC['vsav_'+j];}); vsavC=nc; saveState(); renderVsav(); };
function renderVsav() {
  const c=document.getElementById('rows-vsav'); c.innerHTML='';
  if(!vsavItems.length){ c.innerHTML='<div class="empty-st">Ajoutez vos équipements ci-dessous</div>'; }
  else vsavItems.forEach((item,i)=>{
    const k='vsav_'+i, st=vsavC[k]||'';
    const row=document.createElement('div'); row.className='check-row';
    row.innerHTML=`<span class="qty-tag">${item.qty}</span><span class="item-name">${item.name}</span>
      <div class="btn-pa">
        <button class="pa-btn ${st==='P'?'p':''}" onclick="vsavChk(${i},'P')">P</button>
        <button class="pa-btn ${st==='A'?'a':''}" onclick="vsavChk(${i},'A')">A</button>
        <button class="del-btn" onclick="delVsav(${i})">×</button>
      </div>`;
    c.appendChild(row);
  });
  const vp=Object.values(vsavC).filter(v=>v==='P').length;
  document.getElementById('prog-vsav').textContent=`${vp}/${vsavItems.length}`;
  updateOv('vsav',vsavC,vsavItems.length);
}
function addVsav() {
  const name=document.getElementById('vsav-new-name').value.trim();
  const qty=document.getElementById('vsav-new-qty').value.trim()||'1';
  if(!name) return;
  vsavItems.push({name,qty});
  document.getElementById('vsav-new-name').value='';
  document.getElementById('vsav-new-qty').value='';
  saveState(); renderVsav();
}
function saveVsavInfo(){ vsavI={realise:document.getElementById('vsav-realise').value,date:document.getElementById('vsav-date').value,garde:document.getElementById('vsav-garde').value,remarques:document.getElementById('vsav-remarques').value}; saveState(); }
function saveVsavControl() {
  const p=Object.values(vsavC).filter(v=>v==='P').length;
  const a=Object.values(vsavC).filter(v=>v==='A').length;
  const absL=vsavItems.map((it,i)=>vsavC['vsav_'+i]==='A'?it.name:null).filter(Boolean);
  history.unshift({type:'vsav',realise:vsavI.realise||'—',garde:vsavI.garde||'—',date:vsavI.date||today(),total:vsavItems.length,p,a,absL,remarques:vsavI.remarques||''});
  saveState();
  autoExportExcel();
  toast('✓ Enregistré — Excel mis à jour 📊'); loadDashboard();
}
function resetVsav(){ if(!confirm('Réinitialiser ?')) return; vsavC={}; saveState(); renderVsav(); }

// ══════════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════════
function loadDashboard() {
  document.getElementById('kpi-total').textContent=history.length;
  document.getElementById('kpi-abs').textContent=history.filter(h=>h.a>0).length;
  document.getElementById('kpi-ok').textContent=history.filter(h=>h.a===0).length;
  if(history.length){
    const last=history[0];
    const lbl=last.type==='sps'?'Sac PS':last.type==='dsa'?'DSA':'VSAV';
    document.getElementById('kpi-sub').textContent=`Dernier : ${lbl} — ${last.date} par ${last.realise}`;
  } else { document.getElementById('kpi-sub').textContent='Aucun contrôle enregistré'; }

  // Alerts
  const alertZ=document.getElementById('alert-zone');
  const issues=history.filter(h=>h.a>0).slice(0,2);
  alertZ.innerHTML=issues.map(h=>{
    const lbl=h.type==='sps'?'Sac PS N°1':h.type==='dsa'?'DSA':'VSAV';
    return `<div class="alert-card"><div class="alert-card-title">🚨 ${lbl} — ${h.date}</div><div class="alert-card-body">• ${h.absL.join('<br>• ')}</div></div>`;
  }).join('');

  // Reminders
  const remZ=document.getElementById('remind-zone');
  const overdue=[];
  ['sps','dsa','vsav'].forEach(t=>{
    const lbl=t==='sps'?'Sac PS':t==='dsa'?'DSA':'VSAV';
    const last=history.find(h=>h.type===t);
    if(!last){ overdue.push(`${lbl} — jamais contrôlé`); return; }
    const diff=(new Date()-new Date(last.date))/(1000*60*60*24);
    if(diff>7) overdue.push(`${lbl} — dernier : ${last.date}`);
  });
  remZ.innerHTML=overdue.length?`<div class="reminder-card"><div class="reminder-title">⏰ Contrôle(s) en retard</div><div class="reminder-body">• ${overdue.join('<br>• ')}</div></div>`:'';

  // Recent
  const rl=document.getElementById('dash-recent');
  if(!history.length){ rl.innerHTML='<div class="empty-st">Aucun contrôle enregistré.</div>'; return; }
  rl.innerHTML=history.slice(0,6).map(h=>histRow(h)).join('');
}

function renderHistory() {
  const c=document.getElementById('hist-list');
  if(!history.length){ c.innerHTML='<div class="empty-st">Aucun contrôle.</div>'; return; }
  c.innerHTML=history.map(h=>histRow(h)).join('');
}

function histRow(h) {
  const lbl=h.type==='sps'?'Sac PS N°1':h.type==='dsa'?'DSA':'VSAV';
  const chip=h.type==='sps'?'chip-sps':h.type==='dsa'?'chip-dsa':'chip-vsav';
  const issues=h.a>0?`<div class="hist-absent">✗ ${h.absL.join(', ')}</div>`:`<div class="hist-ok">✓ Aucun absent</div>`;
  const bat=h.battery?` · Batterie : ${h.battery==='ok'?'OK':'⚠ Faible'}`:'';
  return `<div class="hist-entry">
    <div class="hist-top">
      <div><div class="hist-name">${h.realise} — ${h.garde}</div><div class="hist-meta">${h.date}</div></div>
      <span class="hist-chip ${chip}">${lbl}</span>
    </div>
    <div class="hist-stats">${h.p}/${h.total} présents${bat}</div>${issues}
    ${h.remarques?`<div style="font-size:11px;color:var(--text3);margin-top:3px;font-style:italic">${h.remarques}</div>`:''}
  </div>`;
}

// ══════════════════════════════════════════════
// EXPORT EXCEL — AUTO + MANUEL
// ══════════════════════════════════════════════
function buildHistoryWorkbook() {
  const wb = XLSX.utils.book_new();

  // ── Feuille 1 : Récap tous contrôles ──
  const headers = ['Date','Type','Réalisé par','Garde','Présents','Total','Absents','Éléments absents','Batterie','Remarques'];
  const rows = [['CS CHANAC — Historique des contrôles'],['Généré le : '+new Date().toLocaleString('fr-FR')],[''],headers];
  history.forEach(h=>{
    const lbl=h.type==='sps'?'Sac PS N°1':h.type==='dsa'?'DSA':'VSAV';
    rows.push([h.date,lbl,h.realise,h.garde,h.p,h.total,h.a,h.absL.join(', '),h.battery||'',h.remarques||'']);
  });
  const ws1 = XLSX.utils.aoa_to_sheet(rows);
  ws1['!cols']=[{wch:12},{wch:12},{wch:18},{wch:10},{wch:9},{wch:7},{wch:8},{wch:38},{wch:10},{wch:28}];
  // Style header row
  XLSX.utils.book_append_sheet(wb, ws1, 'Historique');

  // ── Feuille 2 : Sac PS détail (dernier) ──
  const lastSps = history.find(h=>h.type==='sps');
  if(lastSps) {
    const spsRows = [['CS CHANAC — Sac PS N°1 (dernier contrôle)'],[''],
      ['Réalisé par', lastSps.realise],['Date', lastSps.date],['Garde', lastSps.garde],['']];
    const secLabels={'pg':'Poche gauche','rouge':'Sacoche rouge','violette':'Sacoche violette','bleue':'Sacoche bleue','devant':'Devant du sac','pcarr':'Poche centrale arrière','verte':'Sacoche verte','pd':'Poche droite'};
    Object.entries(SPS).forEach(([sec,items])=>{
      spsRows.push([secLabels[sec]||sec]);
      spsRows.push(['Qté','Équipement','Statut']);
      items.forEach(([qty,name],i)=>{
        const st=spsC[sec+'_'+i]||'';
        spsRows.push([qty,name,st==='P'?'✓ Présent':st==='A'?'✗ Absent':'— Non vérifié']);
      });
      spsRows.push(['']);
    });
    if(lastSps.remarques) spsRows.push(['Remarques',lastSps.remarques]);
    const ws2=XLSX.utils.aoa_to_sheet(spsRows);
    ws2['!cols']=[{wch:8},{wch:36},{wch:14}];
    XLSX.utils.book_append_sheet(wb,ws2,'Sac PS — Détail');
  }

  // ── Feuille 3 : DSA dernier ──
  const lastDsa = history.find(h=>h.type==='dsa');
  if(lastDsa) {
    const dsaRows=[['CS CHANAC — DSA (dernier contrôle)'],[''],
      ['Réalisé par',lastDsa.realise],['Date',lastDsa.date],['Garde',lastDsa.garde],[''],
      ['Qté','Équipement','Statut']];
    DSA_LIST.forEach(([qty,name],i)=>{
      const st=dsaC['dsa_'+i]||'';
      dsaRows.push([qty,name,st==='P'?'✓ Présent':st==='A'?'✗ Absent':'— Non vérifié']);
    });
    dsaRows.push(['','Batterie',dsaBat==='ok'?'✓ OK':dsaBat==='low'?'⚠ Faible':'—']);
    if(lastDsa.remarques) dsaRows.push([''],['Remarques',lastDsa.remarques]);
    const ws3=XLSX.utils.aoa_to_sheet(dsaRows);
    ws3['!cols']=[{wch:8},{wch:42},{wch:14}];
    XLSX.utils.book_append_sheet(wb,ws3,'DSA — Détail');
  }

  // ── Feuille 4 : VSAV dernier ──
  const lastVsav = history.find(h=>h.type==='vsav');
  if(lastVsav && vsavItems.length) {
    const vRows=[['CS CHANAC — VSAV (dernier contrôle)'],[''],
      ['Réalisé par',lastVsav.realise],['Date',lastVsav.date],['Garde',lastVsav.garde],[''],
      ['Qté','Équipement','Statut']];
    vsavItems.forEach((it,i)=>{
      const st=vsavC['vsav_'+i]||'';
      vRows.push([it.qty,it.name,st==='P'?'✓ Présent':st==='A'?'✗ Absent':'— Non vérifié']);
    });
    if(lastVsav.remarques) vRows.push([''],['Remarques',lastVsav.remarques]);
    const ws4=XLSX.utils.aoa_to_sheet(vRows);
    ws4['!cols']=[{wch:8},{wch:36},{wch:14}];
    XLSX.utils.book_append_sheet(wb,ws4,'VSAV — Détail');
  }

  return wb;
}

function autoExportExcel() {
  if(!history.length) return;
  const wb = buildHistoryWorkbook();
  XLSX.writeFile(wb, `Chanac_Inventaires_${today()}.xlsx`);
}

function exportAllExcel() {
  if(!history.length){ toast('Aucun contrôle à exporter'); return; }
  const wb = buildHistoryWorkbook();
  XLSX.writeFile(wb, `Chanac_Inventaires_Complet_${today()}.xlsx`);
  toast('📊 Excel complet téléchargé');
}

